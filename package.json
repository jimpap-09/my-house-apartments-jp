{
  "name": "my-house-apartments-jp",
  "version": "1.0.0",
  "description": "Enjoy my 2 house apartments",
  "keywords": [
    "jp"
  ],
  "homepage": "https://github.com/jimpap-09/my-house-apartments-jp#readme",
  "bugs": {
    "url": "https://github.com/jimpap-09/my-house-apartments-jp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jimpap-09/my-house-apartments-jp.git"
  },
  "license": "ISC",
  "author": "JP",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "start": "concurrently \"npm start --prefix frontend\" \"npm start --prefix backend\"",

    "dev": "concurrently -n FRONTEND,BACKEND \"npm run dev --prefix frontend\" \"npm run dev --prefix backend\"",
    "dev-session": "bash backend/scripts/dev-session.sh",

    "generate:api": "bash backend/scripts/api/generate-api.sh",
    "generate:erd": "node backend/scripts/db/generate-erd.js",
    "generate:db": "cross-env NODE_ENV=development bash backend/scripts/db/generate-db.sh",
    "generate:seeders": "node backend/scripts/db/generate-seeders.js",

    "test:api": "node backend/scripts/api-test.js",
    "test:env": "cross-env NODE_ENV=development node -e \"console.log(process.env.NODE_ENV)\"",

    "db:shell": "bash backend/scripts/shell-db.sh",
    "db:test": "node backend/scripts/connect-db.js",
    "db:status": "bash backend/scripts/status-db.sh",
    "db:drop": "bash backend/scripts/drop-shema.sh",
    "db:setup": "bash backend/scripts/setup-db.sh",

    "upload:images": "node backend/scripts/cloudinary/upload-cloudinary-images.js",
    "rename:image": "node backend/scripts/cloudinary/rename-cloudinary-image.js",
    "reset:all": "npm run db:drop && npm run db:setup && npm run generate:api && npm run generate:erd"
  },
  "dependencies": {
    "alias": "^0.0.5",
    "axios": "^1.16.1",
    "chalk": "^4.1.2",
    "cloudinary": "^2.10.0",
    "color-convert": "^2.0.1",
    "color-name": "^1.1.4",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "escalade": "^3.2.0",
    "get-caller-file": "^2.0.5",
    "has-flag": "^4.0.0",
    "is-fullwidth-code-point": "^3.0.0",
    "nodemon": "^3.1.14",
    "pg": "^8.21.0",
    "pg-hstore": "^2.3.4",
    "require-directory": "^2.1.1",
    "rxjs": "^7.8.2",
    "sequelize": "^6.37.8",
    "shell-quote": "^1.8.3",
    "supports-color": "^8.1.1",
    "tree-kill": "^1.2.2",
    "tslib": "^2.8.1",
    "tsx": "^4.22.3",
    "y18n": "^5.0.8"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "sequelize-cli": "^6.6.5"
  }
}
