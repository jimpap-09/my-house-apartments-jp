{
    "models": [
        {
            "name": "Apartment",
            "primaryKey": "id",
            "options": {
                "timestamps": true
            },
            "attributes": {
                "id": {
                    "type": "integer",
                    "primaryKey": true,
                    "autoIncrement": true
                },
                "title": {
                    "type": "string",
                    "allowNull": false
                },
                "description": {
                    "type": "text",
                    "allowNull": true
                },
                "pricePerNight": {
                    "type": "float",
                    "allowNull": false,
                    "defaultValue": 0
                },
                "location": {
                    "type": "string",
                    "allowNull": false
                },
                "urlCover": {
                    "type": "string",
                    "allowNull": false
                }
            }
        },
        {
            "name": "ApartmentImage",
            "primaryKey": "id",
            "options": {
                "timestamps": true
            },
            "attributes": {
                "id": {
                    "type": "integer",
                    "primaryKey": true,
                    "autoIncrement": true
                },
                "apartmentId": {
                    "type": "integer",
                    "allowNull": false,
                    "references": {
                        "model": "Apartment",
                        "key": "id"
                    },
                    "onUpdate": "CASCADE",
                    "onDelete": "CASCADE"
                },
                "url": {
                    "type": "string",
                    "allowNull": false
                },
                "alt": {
                    "type": "string",
                    "allowNull": false
                },
                "sortOrder": {
                    "type": "integer",
                    "allowNull": false,
                    "defaultValue": 0
                },
                "isCover": {
                    "type": "boolean",
                    "allowNull": false,
                    "defaultValue": false
                }
            }
        },
        {
            "name": "User",
            "primaryKey": "id",
            "options": {
                "timestamps": true
            },
            "attributes": {
                "id": {
                    "type": "integer",
                    "primaryKey": true,
                    "autoIncrement": true
                },
                "username": {
                    "type": "string",
                    "allowNull": true
                },
                "password": {
                    "type": "string",
                    "allowNull": true
                },
                "firstName": {
                    "type": "string",
                    "allowNull": true
                },
                "lastName": {
                    "type": "string",
                    "allowNull": true
                },
                "email": {
                    "type": "string",
                    "allowNull": false,
                    "unique": true
                },
                "phone": {
                    "type": "string",
                    "allowNull": false,
                    "unique": true
                },
                "role": {
                    "type": "string",
                    "allowNull": false,
                    "defaultValue": "user",
                    "validate": {
                        "isIn": [
                            [
                                "user",
                                "admin"
                            ]
                        ]
                    }
                }
            }
        },
        {
            "name": "Review",
            "uniqueConstraints": [
                [
                    "userId",
                    "apartmentId"
                ]
            ],
            "primaryKey": "id",
            "options": {
                "timestamps": true
            },
            "attributes": {
                "id": {
                    "type": "integer",
                    "primaryKey": true,
                    "autoIncrement": true
                },
                "rating": {
                    "type": "integer",
                    "allowNull": false,
                    "validate": {
                        "min": 1,
                        "max": 5
                    }
                },
                "comment": {
                    "type": "text",
                    "allowNull": true
                },
                "userId": {
                    "type": "integer",
                    "allowNull": false,
                    "references": {
                        "model": "User",
                        "key": "id"
                    },
                    "onUpdate": "CASCADE",
                    "onDelete": "CASCADE"
                },
                "apartmentId": {
                    "type": "integer",
                    "allowNull": false,
                    "references": {
                        "model": "Apartment",
                        "key": "id"
                    },
                    "onUpdate": "CASCADE",
                    "onDelete": "CASCADE"
                }
            }
        },
        {
            "name": "Reservation",
            "indexes": [
                [
                    "apartmentId",
                    "checkIn",
                    "checkOut"
                ]
            ],
            "primaryKey": "id",
            "options": {
                "timestamps": true
            },
            "attributes": {
                "id": {
                    "type": "integer",
                    "primaryKey": true,
                    "autoIncrement": true
                },
                "checkIn": {
                    "type": "date",
                    "allowNull": false
                },
                "checkOut": {
                    "type": "date",
                    "allowNull": false
                },
                "userId": {
                    "type": "integer",
                    "allowNull": false,
                    "references": {
                        "model": "User",
                        "key": "id"
                    },
                    "onUpdate": "CASCADE",
                    "onDelete": "CASCADE"
                },
                "apartmentId": {
                    "type": "integer",
                    "allowNull": false,
                    "references": {
                        "model": "Apartment",
                        "key": "id"
                    },
                    "onUpdate": "CASCADE",
                    "onDelete": "CASCADE"
                }
            }
        }
    ],
    "relations": [
        {
            "source": "Apartment",
            "target": "ApartmentImage",
            "type": "hasMany",
            "foreignKey": "apartmentId"
        },
        {
            "source": "ApartmentImage",
            "target": "Apartment",
            "type": "belongsTo",
            "foreignKey": "apartmentId"
        },
        {
            "source": "User",
            "target": "Review",
            "type": "hasMany",
            "foreignKey": "userId"
        },
        {
            "source": "Review",
            "target": "User",
            "type": "belongsTo",
            "foreignKey": "userId"
        },
        {
            "source": "Apartment",
            "target": "Review",
            "type": "hasMany",
            "foreignKey": "apartmentId"
        },
        {
            "source": "Review",
            "target": "Apartment",
            "type": "belongsTo",
            "foreignKey": "apartmentId"
        },
        {
            "source": "User",
            "target": "Reservation",
            "type": "hasMany",
            "foreignKey": "userId"
        },
        {
            "source": "Reservation",
            "target": "User",
            "type": "belongsTo",
            "foreignKey": "userId"
        },
        {
            "source": "Apartment",
            "target": "Reservation",
            "type": "hasMany",
            "foreignKey": "apartmentId"
        },
        {
            "source": "Reservation",
            "target": "Apartment",
            "type": "belongsTo",
            "foreignKey": "apartmentId"
        }
    ]
}